# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string

# Database (production)
POSTGRES_DB=codecompare
POSTGRES_USER=codecompare
POSTGRES_PASSWORD=strongpassword
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3

# Security (production)
ALLOWED_HOSTS=codecompare.example.com,www.codecompare.example.com
CORS_ALLOWED_ORIGINS=https://codecompare.example.com
SECURE_SSL_REDIRECT=true

# Static/media files
STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media

# Docker image
IMAGE_TAG=codecompare:latest
